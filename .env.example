# Copy to .env.local for local dev. On Vercel, set these in Project Settings → Environment Variables.

# AI chatbot (/api/chat) — required for SolarBot to respond
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Lead notifications — REQUIRED in production or leads are only console-logged (lost)
POSTMARK_SERVER_TOKEN=
CONTACT_EMAIL_TO=cal@renewably.ie
# Must be a verified sender signature in Postmark:
CONTACT_EMAIL_FROM=

# Site URL (used for sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://renewableireland.ie

# Database (Prisma — currently unused by any route; schema is scaffold only)
DATABASE_URL=file:./db/custom.db

# AISOLAR platform ingestion — forwards website leads into the pipeline
AISOLAR_INGEST_URL=
AISOLAR_INGEST_KEY=
